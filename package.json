{
  "name": "teaminal",
  "version": "0.0.0",
  "description": "Lightweight terminal Microsoft Teams client",
  "type": "module",
  "bin": {
    "teaminal": "./bin/teaminal.ts"
  },
  "scripts": {
    "dev": "bun run bin/teaminal.ts",
    "build": "bash scripts/build.sh",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "dependencies": {
    "entities": "^8.0.0",
    "htmlparser2": "^12.0.0",
    "ink": "^7.0.1",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
