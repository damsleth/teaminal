{
  "name": "teaminal",
  "version": "0.19.0",
  "license": "MIT",
  "description": "Lightweight terminal Microsoft Teams client",
  "type": "module",
  "engines": {
    "bun": ">=1.3.5"
  },
  "bin": {
    "teaminal": "./bin/teaminal.tsx"
  },
  "scripts": {
    "dev": "bun run bin/teaminal.tsx --log-file .tmp/events.log --network-log .tmp/network.log",
    "dev:watch": "bun --watch run bin/teaminal.tsx --log-file .tmp/events.log --network-log .tmp/network.log",
    "build": "bash scripts/build.sh",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "e2e": "bun run e2e/runner.ts",
    "typecheck": "bun x tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "tui:flows": "bun run scripts/tui-loop.ts flows",
    "tui:shots": "node node_modules/@microsoft/tui-test/index.js",
    "tui:update": "node node_modules/@microsoft/tui-test/index.js --updateSnapshot",
    "tui:trace": "node node_modules/@microsoft/tui-test/index.js --trace",
    "tui:manifest": "bun run scripts/tui-loop.ts manifest"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "entities": "^8.0.0",
    "htmlparser2": "^12.0.0",
    "ink": "^7.0.4",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@microsoft/tui-test": "latest",
    "@types/bun": "latest",
    "@types/react": "^19.2.15",
    "prettier": "^3.8.3",
    "react-devtools-core": "^7.0.1",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@swc/core"
  ]
}
